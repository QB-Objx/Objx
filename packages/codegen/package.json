{
  "name": "@qbobjx/codegen",
  "version": "0.4.0",
  "private": false,
  "type": "module",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/QB-Objx/Objx"
  },
  "homepage": "https://github.com/QB-Objx/Objx",
  "bugs": {
    "url": "https://github.com/QB-Objx/Objx/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "objx-codegen": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "peerDependencies": {
    "mysql2": "^3.0.0",
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "mysql2": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  }
}
