* text=auto

# Source and config files should use LF across platforms.
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.md text eol=lf
*.sql text eol=lf
*.sh text eol=lf
*.css text eol=lf
*.html text eol=lf
*.gitignore text eol=lf
*.gitattributes text eol=lf

# Common binary assets.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.sqlite binary
