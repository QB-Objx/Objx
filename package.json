{
  "name": "objx",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "benchmark": "npm run build && node examples/benchmarks/src/run.mjs",
    "changeset": "npx @changesets/cli@2.29.7",
    "codegen": "node packages/codegen/dist/cli.js",
    "lint": "eslint .",
    "prepare": "node scripts/setup-husky.mjs",
    "publish:ci": "npm run build && npm run release",
    "publish:local": "node scripts/publish-local.mjs",
    "publish:local:dry-run": "node scripts/publish-local.mjs --dry-run --skip-published-check",
    "release": "npx @changesets/cli@2.29.7 publish",
    "smoke:packages": "npm run build && node scripts/smoke-install.mjs",
    "typecheck": "tsc -b --pretty",
    "test:integration": "npm run build && node tests/integration.test.mjs",
    "test": "npm run build && node tests/session.test.mjs && node tests/codegen.test.mjs && node tests/validation.test.mjs",
    "version-packages": "npx @changesets/cli@2.29.7 version"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/node": "^24.3.0",
    "eslint": "^9.26.0",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0"
  }
}
